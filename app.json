{
  "expo": {
    "name": "حكايتي AI",
    "slug": "mystory",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mystory",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "favicon": "./assets/favicon.png",
    "android": {
      "package": "com.mohammed5577.mystory",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0f0720",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "ios": {
      "bundleIdentifier": "com.mohammed5577.mystory",
      "supportsTablet": true,
      "icon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0720",
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d669a30a-fe5b-40b1-96e3-8089130fff5b"
      }
    },
    "owner": "mohammed5577"
  }
}
